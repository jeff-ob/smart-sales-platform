# Configuration Environment Variables
# Copy this file to .env and fill in your values

# Database
DB_PATH=sales.db

# Data
DATA_DIR=data
RAW_FILE=sales_raw.csv

# ML Models
MODEL_DIR=ml/saved_models

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Note: This project doesn't require API keys or secrets
# This file is here to demonstrate best practices
